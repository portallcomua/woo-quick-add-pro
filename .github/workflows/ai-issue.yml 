name: AI Issue Worker

on:
  issues:
    types: [opened, edited]
  workflow_dispatch:

permissions:
  contents: write
  issues: write
  pull-requests: write

jobs:
  release:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Repository ready
        run: |
          echo "AI Issue Worker started"
          echo "Repository: ${{ github.repository }}"
          echo "Issue: ${{ github.event.issue.number }}"

      - name: Done
        run: echo "Workflow is installed successfully." 